# Copy this file to .env.local (or .env) and adjust as needed.
# All variables are optional — the app works with zero configuration,
# connecting to a gesture engine on localhost:8000 by default.

# WebSocket URL for the Phase 2 gesture engine (gesture-engine/).
# The gesture engine needs local webcam access, so it's expected to run
# on the same machine as the browser viewing this app.
VITE_GESTURE_WS_URL=ws://localhost:8000/ws/gestures
